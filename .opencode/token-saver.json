{
  "truncate": {
    "bash": {
      "maxChars": 5000,
      "enabled": false
    },
    "read": {
      "maxChars": 2000,
      "enabled": true
    },
    "grep": {
      "maxChars": 800,
      "enabled": true
    },
    "glob": {
      "maxChars": 500,
      "enabled": true
    },
    "webfetch": {
      "maxChars": 2000,
      "enabled": true
    },
    "websearch": {
      "maxChars": 1500,
      "enabled": true
    },
    "task": {
      "maxChars": 2000,
      "enabled": true
    }
  },
  "neverTruncatePatterns": [
    "package.json",
    "tsconfig.json",
    "opencode.json",
    "token-saver.json",
    "token-saver.jsonc",
    ".env",
    "SKILL.md"
  ],
  "compacting": {
    "enabled": true,
    "maxSummaryChars": 2000
  },
  "trim": {
    "defaultKeepLast": 10
  }
}
